# Optional analytics — enable ONE option, then copy to .env.local for local builds.
# For GitHub Actions, add the same names as repository secrets (see README).

# Plausible (official NPM tracker is bundled — set domain as in Plausible site settings)
# VITE_PLAUSIBLE_DOMAIN=antoniosifov.com
# Self-hosted / proxy only — full event URL (default is https://plausible.io/api/event)
# VITE_PLAUSIBLE_ENDPOINT=https://your-plausible.example.com/api/event
# Send events from localhost during dev (optional)
# VITE_PLAUSIBLE_CAPTURE_LOCALHOST=true

# Google Analytics 4 (alternative)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
