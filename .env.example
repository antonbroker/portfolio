# Optional analytics — set at build time. For GitHub Actions, add as repository Secrets.
#
# Plausible: domain must match EXACTLY what you entered in Plausible (antoniosifov.com vs www.antoniosifov.com).
# After creating/updating secrets, re-run the “Deploy to GitHub Pages” workflow (or push an empty commit).

# VITE_PLAUSIBLE_DOMAIN=antoniosifov.com
# Self-hosted Plausible — script URL (default is https://plausible.io/js/script.js)
# VITE_PLAUSIBLE_SCRIPT_URL=https://your-plausible.example/js/script.js

# Google Analytics 4 (use only if you are not using Plausible)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
